#!/bin/sh
set -eu

if [ "${SKYFALL_SKIP_AUTO_PUSH:-}" = "1" ]; then
  exit 0
fi

branch="$(git branch --show-current)"
if [ -z "$branch" ]; then
  echo "[post-commit] Detached HEAD; skipping auto-push." >&2
  exit 0
fi

remote="${SKYFALL_AUTO_PUSH_REMOTE:-origin}"
if ! git remote get-url "$remote" >/dev/null 2>&1; then
  echo "[post-commit] Remote '$remote' does not exist; skipping auto-push." >&2
  exit 0
fi

if git rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1; then
  git push
else
  git push -u "$remote" "$branch"
fi
